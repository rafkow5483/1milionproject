            if show_lines2 and not na(ghost_level2[1])
                line.set_x2(ghost_level2[1], px12)

            if show_lines2
                ghost_level2 := line.new(px12, py12, px12, py12, color=color.new(reg_ph_css2, 50), width=2)

        else if pl2 > min2
            label.new(follow_max_x12, follow_max2, "👻", color=miss_ph_css2, style=label.style_label_down, size=size.small, tooltip=str.tostring(max2, "#.####"))
            label.new(min_x12, min2, "👻", color=miss_pl_css2, style=label.style_label_up, size=size.small, tooltip=str.tostring(min2, "#.####"))

            if show_lines2
                zigzag2 := line.new(px12, py12, min_x12, min2, color=miss_ph_css2, style=line.style_dashed)

