            if show_lines2
                ghost_level2 := line.new(px12, py12, px12, py12, color=color.new(reg_pl_css2, 50), width=2)

        else if ph2 < max2
            label.new(max_x12, max2, "👻", color=miss_ph_css2, style=label.style_label_down, size=size.small, tooltip=str.tostring(max2, "#.####"))
            label.new(follow_min_x12, follow_min2, "👻", color=miss_pl_css2, style=label.style_label_up, size=size.small, tooltip=str.tostring(min2, "#.####"))

            if show_lines2
                zigzag2 := line.new(px12, py12, max_x12, max2, color=miss_pl_css2, style=line.style_dashed)

            px12 := max_x12
