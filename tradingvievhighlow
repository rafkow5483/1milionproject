            if show_lines2 and not na(ghost_level2[1])
                line.set_x2(ghost_level2[1], px12)

            if show_lines2
                ghost_level2 := line.new(px12, py12, px12, py12, color=color.new(reg_ph_css2, 50), width=2)

            if show_lines2
                zigzag2 := line.new(px12, py12, follow_min_x12, follow_min2, color=miss_ph_css2, style=line.style_dashed)

            px12 := follow_min_x12
            py12 := follow_min2

            if show_lines2 and not na(ghost_level2)
                line.set_x2(ghost_level2, px12)

            if show_lines2
                ghost_level2 := line.new(px12, py12, px12, py12, color=color.new(reg_pl_css2, 50), width=2)

    if show_reg2
        label.new(n - length2, ph2, "▼", textcolor=label_css2, color=reg_ph_css2, style=label.style_label_down, size=size.small, tooltip=str.tostring(ph2, "#.####"))

        if show_lines2
            zigzag2 := line.new(px12, py12, n - length2, ph2, color=miss_pl_css2, style=ph2 < max2 or os2[1] == 1 ? line.style_dashed : line.style_solid)

    py12 := ph2
    px12 := n - length2
